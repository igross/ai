\begin_layout Subsection*
Matching Steady States
\end_layout

\begin_layout Standard
To find the steady state of the employment equation 
\begin_inset Formula $n_{t}=(1-\rho)n_{t-1}+m_{t-1}$
\end_inset

,
 we use the fact that 
\begin_inset Formula $u=(1-n)$
\end_inset

 and 
\begin_inset Formula $m_{t}=\bar{m}v_{t}^{1-\mu}u_{t}^{\mu}.$
\end_inset

 Substituting and getting rid of time subscript gives 
\begin_inset Formula $(1-u)=(1-\rho)(1-u)+\bar{m}v^{1-\mu}u^{\mu}$
\end_inset

 which simplifies to 
\begin_inset Formula $\bar{m}v_{t}^{1-\mu}u_{t}^{\mu}=$
\end_inset


\begin_inset Formula $\rho(1-u)$
\end_inset

.
 Making 
\begin_inset Formula $v\text{\,the subject of the foruma gives us the Beveridge curve.}$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
v=\left(\frac{\rho(1-u)}{\bar{mu}}\right)^{1-\mu}u
\]

\end_inset

The steady state for the JCC can be found by using 
\begin_inset Formula $\frac{\kappa}{q(\theta_{t})}=A-w_{t}+\beta E_{t}\left[A-w_{t+1}+(1-\rho)\frac{\kappa}{q(\theta_{t+1})}\right]$
\end_inset

 and 
\begin_inset Formula $q(\theta_{t})=\bar{m}\theta_{t}^{-\mu}=\bar{m}\left(\frac{v_{t}}{u_{t}}\right)^{-\mu}$
\end_inset

.
 Substituting and getting rid of time subscripts yields 
\begin_inset Formula 
\[
\frac{\kappa}{\bar{m}}\left(\frac{v}{u}\right)^{\mu}=A-w_{t}+\beta\left[A-w+(1-\rho)\frac{\kappa}{\bar{m}}\left(\frac{v}{u}\right)^{\mu}\right]
\]

\end_inset


\end_layout

\begin_layout Standard
Simplifying yields the steady state of the JCC
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
1-\beta(1-\rho)\frac{\kappa}{\bar{m}}\left(\frac{v}{u}\right)^{\mu}=(1+\beta)\left[A-w\right]
\]

\end_inset


\end_layout

