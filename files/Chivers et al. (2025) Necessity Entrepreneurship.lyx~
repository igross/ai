\begin_layout Subsection
Firm manager
\end_layout

\begin_layout Standard
Firms are distinguished by their productivity realization 
\begin_inset Formula $x$
\end_inset

.
 Agents with sufficient ability to become managers choose the level of capital and the number of employees to maximize profit subject to a technological constraint.
 In order to simplify the exposition,
 first consider the problem of a manager with talent 
\begin_inset Formula $x^{i}$
\end_inset

 for a given level of capital 
\begin_inset Formula $k$
\end_inset

 (i.e.,
 labor input choice only):
 
\begin_inset Formula 
\begin{equation}
\max_{zn}xk^{\alpha}(zn){}^{\gamma}-zw(1+\psi\tau)n-rk-\kappa\frac{\rho zn}{q(\theta)}\label{maxP}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
The first order conditions are:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
\gamma xk^{\alpha}zn^{\gamma-1}-w(1+\psi\tau)-rk-\frac{\rho\kappa}{q(\theta)}\label{maxP-1}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
n^{*}(k,x,\widetilde{w})=\left[\frac{\gamma xk}{(w(1+\psi\tau)+\frac{\rho\kappa}{q(\theta)}}\right]{}^{^{\frac{1}{1-\gamma}}}\label{FOC}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
Substituting (
\begin_inset CommandInset ref
LatexCommand ref
reference "FOC"
nolink "false"

\end_inset

) into (
\begin_inset CommandInset ref
LatexCommand ref
reference "maxP"
nolink "false"

\end_inset

) yields the manager's profit function for a given level of capital:
\begin_inset Formula 
\begin{equation}
y(k,x,\widetilde{w})=xk\left[\frac{\gamma xk^{\alpha}}{(w(1+\psi\tau)+\frac{\rho\kappa}{q(\theta)}}\right]^{\frac{\gamma}{1-\gamma}}\label{profitj}
\end{equation}

\end_inset


\end_layout

\begin_layout Subsubsection
Capital
\end_layout

\begin_layout Standard
Initially we assume capital markets function perfectly.
\end_layout

\begin_layout Subsection
Entrepreneurs
\end_layout

\begin_layout Standard
Entrepreneurs maximize expected discounted utility of consumption 
\begin_inset Formula 
\[
\max_{\{c_{t},a_{t+1}\}}\mathbb{E}\sum_{t=0}^{\infty}\beta^{t}U(c_{t})
\]

\end_inset

subject to the following budget constraint:
 
\begin_inset Formula 
\begin{align}
c+a' & \leq(1+r-\delta)a+\nu-\tau_{\pi}\label{eq:c_worker-3}
\end{align}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
a'\geq-\bar{a}
\]

\end_inset


\end_layout

\begin_layout Subsection
Employed
\end_layout

\begin_layout Standard
The workforce (previous periods employed who choose to reapply for work) maximize expected discounted utility of consumption 
\begin_inset Formula 
\[
\max_{\{c_{t},a_{t+1}\}}\mathbb{E}\sum_{t=0}^{\infty}\beta^{t}U(c_{t})
\]

\end_inset

subject to the following budget constraint:
 
\begin_inset Formula 
\begin{align}
c+a' & \leq(1+r-\delta)a+(1-\rho)\left(wz(1-(1-\psi)\tau_{y})\right)+\rho b\label{eq:c_worker}
\end{align}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
a'\geq-\bar{a}
\]

\end_inset

where 
\begin_inset Formula $b$
\end_inset

 is the unemployment benefit.
\end_layout

\begin_layout Subsection
Unemployed
\end_layout

\begin_layout Standard
The unemployed maximize expected discounted utility of consumption 
\begin_inset Formula 
\[
\max_{\{c_{t},a_{t+1}\}}\mathbb{E}\sum_{t=0}^{\infty}\beta^{t}U(c_{t})
\]

\end_inset

subject to the following budget constraint:
 
\begin_inset Formula 
\begin{align}
c+a' & \leq(1+r-\delta)a+p(\theta)\left(wz(1-(1-\psi)\tau_{y})\right)+(1-p(\theta))b\label{eq:c_worker-2}
\end{align}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
a'\geq-\bar{a}
\]

\end_inset

where 
\begin_inset Formula $b$
