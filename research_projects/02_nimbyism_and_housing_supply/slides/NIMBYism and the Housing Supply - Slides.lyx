\begin_deeper
\begin_layout Standard
Household wish to maximize expected lifetime utility, by choosing consumption,
 
\begin_inset Formula $c_{t}$
\end_inset

, liquid assets,
\begin_inset Formula $a_{t}$
\end_inset

, and housing, 
\begin_inset Formula $h_{t}$
\end_inset

, bequests 
\begin_inset Formula $w_{J+1},$
\end_inset

 at each age 
\begin_inset Formula $j$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
U=\sum_{j=1}^{J}E\beta^{j}u(c_{j},h_{j})+\beta^{J}\left(w_{J+1}\right)
\]

\end_inset

where the consumption of housing stock consists of either the amount of
 housing owned or rented
\begin_inset Formula 
\[
h_{t}=\begin{cases}
\theta^{rent}h_{t}^{rent} & \mbox{if }h_{t}=0\\
h_{t}^{own} & \mbox{if }h_{t}>0
\end{cases}
\]

\end_inset


\end_layout

\begin_layout Standard
There is a warm glow bequest function when households die that provides
 utility of 
\begin_inset Formula $v(w)=\overline{w}\frac{\left(w+\overline{w}\right)^{1-\gamma}}{1-\gamma}.$
\end_inset

 where 
\begin_inset Formula $\phi$
\end_inset

, 
\begin_inset Formula $\overline{w}$
\end_inset

 are scaling parameters 
\end_layout

\end_deeper
