\begin_deeper
\begin_layout Standard
\begin_inset Quotes eld
\end_inset

Superstar Incomes
\begin_inset Quotes erd
\end_inset

: household's supply their labor inelastically.
 
\begin_inset Formula $y$
\end_inset

 is wage, 
\begin_inset Formula $z$
\end_inset

 is a Markov process calibrated (as per Kindermann and Krueger, 2022) and
 
\begin_inset Formula $g_{j}$
\end_inset

 is a deterministic age profile.
\begin_inset Formula 
\[
\text{ln}y_{t,j}=g_{j}+z_{t}
\]

\end_inset


\end_layout

\begin_layout Standard
Each household can borrow against a proportion, 
\begin_inset Formula $M$
\end_inset

, of the total value of the stock of housing they own.
 Households may buy or sell housing at price, 
\begin_inset Formula $p_{t}^{h},$
\end_inset

 subject to a minimum block size 
\begin_inset Formula $\bar{h}$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
a_{t}\geq-Mh_{t}p_{t}^{h}.
\]

\end_inset


\end_layout

\begin_layout Standard
All property sales are subject to a transaction cost 
\begin_inset Formula $F_{s}$
\end_inset


\end_layout

