\begin_deeper
\begin_layout Standard
\begin_inset Formula 
\begin{eqnarray*}
V_{j}^{rent}\left(a_{t},h_{t},z_{t}\right) & = & \underset{c_{t},a_{t},h_{t}^{rent}}{\mbox{max}}u\left(c_{t},h_{t}^{rent}\right)+\beta EV_{j+1}\left(c_{t+1},h_{t+1},z_{t+1}\right)\\
s.t\\
a_{t+1} & = & \left(1+r_{t}^{a}\right)a_{t}+y_{t}-c_{t}-p_{t}^{rent}h_{t}^{rent}+\left(1-F_{s}\right)p_{t}^{h}h_{t}\\
a_{t+1} & \geq & 0\\
h_{t+1} & = & 0
\end{eqnarray*}

\end_inset


