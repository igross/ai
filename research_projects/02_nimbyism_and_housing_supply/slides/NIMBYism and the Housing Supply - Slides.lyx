\begin_inset Formula 
\begin{eqnarray*}
V_{j}^{adjust}\left(a_{t},h_{t},z_{t}\right) & = & \underset{c_{t},a_{t},h_{t}}{\mbox{max}}u\left(c_{t},h_{t}\right)+\beta EV_{j+1}\left(a_{t+1},h_{t+1},z_{t+1}\right)\\
s.t\\
a_{t+1} & = & \left(1+r_{t}^{a}\right)a_{t}+y_{t}-c_{t}+I^{sell}\left(1-F_{s}\right)p_{t}^{h}\varDelta h_{t}^{own}\\
 &  & -I^{buy}\left(1-F_{b}\right)p_{t}^{h}\varDelta h_{t}^{own}\\
a_{t} & \geq & -mp_{t}h_{t}\\
h_{t+1} & = & h_{t}+\varDelta h_{t}^{own}
\end{eqnarray*}

