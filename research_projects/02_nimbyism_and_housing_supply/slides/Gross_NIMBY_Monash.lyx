\begin_deeper
\begin_layout Standard
Household wish to maximise expected lifetime utility,
 by choosing consumption,
 
\begin_inset Formula $c_{t}$
\end_inset

,
 liquid assets,
\begin_inset Formula $a_{t}$
\end_inset

,
 and housing,
 
\begin_inset Formula $h_{t}$
\end_inset

 at each age 
\begin_inset Formula $j$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
U=\sum_{j=1}^{J}E\beta^{j}u(c_{j},h_{j})+\beta^{J}\left(w_{J+1}\right)
\]

\end_inset


\end_layout

\end_deeper
