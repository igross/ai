\end_inset


\begin_inset ERT
status open

\begin_layout Plain Layout


\backslash
label{Question}
\end_layout

\end_inset


\end_layout

\begin_deeper
\begin_layout Standard
The value function for non-adjusters is 
\begin_inset Formula 
\begin{eqnarray*}
V_{j}^{non-adjusters}\left(a_{t},h_{t},z_{t}\right) & = & \underset{c_{t},a_{t}}{\mbox{max}}u\left(c_{t},h_{t}\right)+\beta EV_{j+1}\left(a_{t+1},h_{t+1},z_{t+1}\right)\\
s.t\\
a_{t+1} & = & \left(1+r_{t}^{a}\right)a_{t}+y_{t}-c_{t}\\
a_{t+1} & \geq & -mp_{t}h_{t}\\
h_{t} & = & h_{t+1}
\end{eqnarray*}

\end_inset


\end_layout

\end_deeper
