\begin_layout Section*
Computation
\end_layout

\begin_layout Standard
Given the values for parameters,
 the discretized spaces 
\begin_inset Formula $\Omega_{a}$
\end_inset

 for 
\begin_inset Formula $a$
\end_inset

,
 
\begin_inset Formula $\Omega_{z}$
\end_inset

 for 
\begin_inset Formula $z$
\end_inset

 and 
\begin_inset Formula $\Omega_{x}$
\end_inset

 for 
\begin_inset Formula $x$
\end_inset

.
 Each agent draw a human capital level 
\begin_inset Formula $h$
\end_inset

 (interpreted as educational attainment) at the beginning of the economy,
 which will be fixed henceforth.
 
\begin_inset Formula $h$
\end_inset

 will determine their labor productivity 
\begin_inset Formula $z\in\Omega_{z}$
\end_inset

,
 the separation rate 
\begin_inset Formula $\rho$
\end_inset

,
 and managerial ability 
\begin_inset Formula $x\in\Omega_{x}$
\end_inset

.
 Let 
\begin_inset Formula $i_{w}=0$
\end_inset

 indicating being entrepreneur,
 
\begin_inset Formula $i_{w}=1$
\end_inset

 being employed and 
\begin_inset Formula $i_{w}=2$
\end_inset

 being unemployed.
 The numerical algorithm works as follows.
 
\end_layout

\begin_layout Enumerate
Set a tolerance 
\begin_inset Formula $\epsilon>0$
\end_inset

.
 
\end_layout

\begin_layout Enumerate
Guess 
\begin_inset Formula $\Phi^{0}=\left(r^{0},w^{0},\rho^{0},\tau_{y}^{0}\right)$
\end_inset

.
 Solve for optimal household behavior:
 
\begin_inset Formula 
\[
f:\left(\varphi;\Phi\right)\rightarrow\left(c,a',\mathcal{I}_{e},n,k\right),
\]

\end_inset

where 
\begin_inset Formula $\varphi=\left\{ h,z,x,a,i_{w}\right\} $
\end_inset

.
 We will use the method of value function iteration as follows.
\end_layout

\begin_deeper
\begin_layout Enumerate
Guess value function 
\begin_inset Formula $\mathbf{V}{}^{0}\left(\varphi;\Phi^{0}\right)$
\end_inset

 and policy functions 
\begin_inset Formula $f^{0}\left(\varphi;\Phi^{0}\right)$
\end_inset

.
 
\end_layout

\begin_layout Enumerate
Calculate the cutoff values of 
\begin_inset Formula $x_{u}^{*}$
\end_inset

 (for previously unemployed worker,
 or entrepreneur) and 
\begin_inset Formula $x_{n}^{*}$
\end_inset

 (for previously employed worker) via the following conditions.
 
\begin_inset Formula 
\begin{align}
\widetilde{w}_{u}= & \pi(x_{u}^{*})=\max_{n}\left\{ \left(x_{u}^{*}\right)^{1-\alpha-\gamma}k^{\alpha}n{}^{\gamma}-w(1+\psi\tau)n-rk-\frac{\kappa zn}{q(\theta)}\right\} \label{eq:xstar_u}\\
\widetilde{w}_{n}= & \pi(x_{n}^{*})=\max_{n}\left\{ \left(x_{n}^{*}\right)^{1-\alpha-\gamma}k^{\alpha}n{}^{\gamma}-w(1+\psi\tau)n-rk-\frac{\kappa zn}{q(\theta)}\right\} \label{eq:xstar_n}
\end{align}

\end_inset

where 
\begin_inset Formula $\widetilde{w}_{n}$
\end_inset

 and 
\begin_inset Formula $\widetilde{w}_{u}$
\end_inset

 denote the expected compensation for the employed worker and unemployed worker respectively.
 More specifically,
 
\begin_inset Formula 
\begin{align}
\widetilde{w}_{n} & =(1-\rho)\left\{ zw(1-(1-\psi)\tau)\right\} +\rho b\label{eq:income_n}\\
\widetilde{w}_{u} & =p(\theta)\left\{ zw(1-(1-\psi)\tau)\right\} p(\theta))b.\label{eq:income_u}
\end{align}

\end_inset

Noting that the separation rate 
\begin_inset Formula $\rho$
\end_inset

 is pre-determined by the individual's initial human capital level 
\begin_inset Formula $h$
\end_inset

.
 
\end_layout

\begin_layout Enumerate
Update value and policy functions:
 
\begin_inset Formula 
\begin{align}
\mathbf{V}^{1}(h,z,x,a,i_{w})=\label{eq:V_overall}\\
\max_{\left\{ a',c,\mathcal{I}_{e}\right\} }\left\{ \begin{array}{c}
\iota_{i_{w}=0}\cdot\left[\begin{array}{c}
(1-\mathcal{I}_{e})\cdot\mathbb{E}_{p(\theta)}\left(V_{w}+\beta\mathbb{E}\mathbf{V}^{0}(h,z',x',a',i'_{w})\right)\\
+\mathcal{I}_{e}\cdot\left(V_{e}+\beta\mathbb{E}\mathbf{V}^{0}(h,z',x',a',i'_{w}=2)\right)
\end{array}\right]+\\
\iota_{i_{w}=1}\cdot\left[\begin{array}{c}
(1-\mathcal{I}_{e})\cdot\mathbb{E}_{\rho}\left(V_{w}+\beta\mathbb{E}\mathbf{V}^{0}(h,z',x',a',i'_{w})\right)\\
+\mathcal{I}_{e}\cdot\left(V_{e}+\beta\mathbb{E}\mathbf{V}^{0}(h,z',x',a',i'_{w}=2)\right)
\end{array}\right]+\\
\iota_{i_{w}=2}\cdot\left[\begin{array}{c}
(1-\mathcal{I}_{e})\cdot\mathbb{E}_{p(\theta)}\left(V_{w}+\beta\mathbb{E}\mathbf{V}^{0}(h,z',x',a',i'_{w})\right)\\
+\mathcal{I}_{e}\cdot\left(V_{e}+\beta\mathbb{E}\mathbf{V}^{0}(h,z',x',a',i'_{w}=2)\right)
\end{array}\right]
\end{array}\right\} \nonumber \\
f^{1}\left(\varphi;\Phi^{0}\right)=\arg\max\mathbf{V}^{1}\left(\varphi;\Phi^{0}\right)\nonumber 
\end{align}

\end_inset

where 
\begin_inset Formula $\mathbb{E}_{p(\theta)}\left(V_{w}+\beta\mathbb{E}\mathbf{V}(a',x',i'_{w})\right)$
\end_inset

 denotes the expected payoff for the individual who is previously unemployed worker,
 or entrepreneur,
 and decides to look for paid job,
 while 
\begin_inset Formula $\mathbb{E}_{\rho}\left(V_{w}+\beta\mathbb{E}\mathbf{V}(a',x',i'_{w})\right)$
\end_inset

 represents the expected payoff for the previously employed worker who decide to stay in workplace.
 
\begin_inset Formula 
\begin{align}
\mathbb{E}_{p(\theta)}\left(V_{w}+\beta\mathbb{E}\mathbf{V}(h,z',x',a',i'_{w})\right) & =p(\theta)\left(V_{n}+\beta\mathbb{E}\mathbf{V}(h,z',x',a',i'_{w}=1)\right)\label{eq:V_u}\\
 & +(1-p(\theta))\left(V_{u}+\beta\mathbb{E}\mathbf{V}(h,z',x',a',i'_{w}=0)\right)\nonumber \\
\mathbb{E}_{\rho}\left(V_{w}+\beta\mathbb{E}\mathbf{V}(h,z',x',a',i'_{w})\right) & =(1-\rho)\left(V_{n}+\beta\mathbb{E}\mathbf{V}(h,z',x',a',i'_{w}=1)\right)\label{eq:V_w}\\
 & +\rho\left(V_{u}+\beta\mathbb{E}\mathbf{V}(h,z',x',a',i'_{w}=0)\right)\nonumber 
\end{align}

\end_inset

To simplify the analysis,
 we assume that the individual who was previously employed and newly separated from the firm is not allowed to search for job at the current period.
 The measure for the individuals who are looking for jobs,
 
\begin_inset Formula $u_{t}$
\end_inset

,
 the total vacancies 
\begin_inset Formula $v_{t}$
\end_inset

,
 and job matching rate 
\begin_inset Formula $\theta_{n,t}$
\end_inset

 are given as follows.
 
\begin_inset Formula 
\begin{align}
u_{t} & =\left(\int_{x}\iota_{i_{w}=0}+\int_{x}\iota_{i_{w}=2}\right)\cdot\int_{0}^{x_{u}^{*}}\label{eq:measure_u}\\
v_{t} & =\int_{x}\iota_{i_{w}=1}\cdot\rho\label{eq:measure_v}\\
\theta_{n,t} & =\bar{m}\left(\frac{v_{t}}{u_{t}}\right)^{1-\mu}\label{eq:measure_matching}
\end{align}

\end_inset

Note that we can write the above value functions explicitly as a system of sub-problems:
 
\begin_inset Formula $P_{x<x_{u}^{*}}^{i_{w}=0}$
\end_inset

 ,
 
\begin_inset Formula $P_{x\geq x_{u}^{*}}^{i_{w}=0}$
\end_inset

,
 
\begin_inset Formula $P_{x<x_{n}^{*}}^{i_{w}=1}$
\end_inset

 ,
 
\begin_inset Formula $P_{x\geq x_{n}^{*}}^{i_{w}=1}$
\end_inset

,
 
\begin_inset Formula $P_{x<x_{u}^{*}}^{i_{w}=2}$
\end_inset

 ,
 
\begin_inset Formula $P_{x\geq x_{u}^{*}}^{i_{w}=2}$
\end_inset

,
 which correspond to the dynamic programing problem for i).
 previously self-employed with 
\begin_inset Formula $x<x_{u}^{*}$
\end_inset

;
 ii).
 previously self-employed with 
\begin_inset Formula $x\geq x_{u}^{*}$
\end_inset

;
 iii).
 previously employed with 
\begin_inset Formula $x<x_{n}^{*}$
\end_inset

;
 iv).
 previously employed with 
\begin_inset Formula $x\geq x_{n}^{*}$
\end_inset

;
 v).
 previously unemployed with 
\begin_inset Formula $x<x_{u}^{*}$
\end_inset

;
 vi).
 previously unemployed with 
\begin_inset Formula $h\geq h_{u}^{*}$
\end_inset

.
 To economize the space,
 we only provide the details for 
\begin_inset Formula $P_{x<x_{u}^{*}}^{i_{w}=0}$
\end_inset

 ,
 and 
\begin_inset Formula $P_{x\geq x_{u}^{*}}^{i_{w}=0}$
\end_inset

 as follows.
 
\begin_inset Newline newline
\end_inset

 
\begin_inset Formula $\left(P_{x<x_{u}^{*}}^{i_{w}=0}\right)$
\end_inset

:
 
\begin_inset Formula 
\begin{equation}
\mathbf{V}^{1}(h,z,x<x_{u}^{*},a,i_{w}=0)=\max_{a'_{n},a'_{u}}\left\{ \begin{array}{c}
p(\theta)\left(u(c_{n})+\beta\mathbb{E}\mathbf{V}^{0}(h,z',x',a'_{n},i'_{w}=1)\right)\\
+(1-p(\theta))\left(u(c_{u})+\beta\mathbb{E}\mathbf{V}^{0}(h,z',x',a'_{u},i'_{w}=0)\right)
\end{array}\right\} \label{eq:V_iw0_xl}
\end{equation}

\end_inset

s.t.
 
\begin_inset Formula 
\begin{align}
c_{n}+a'_{n} & \leq(1-\tilde{r}-\delta)a+zw(1-(1-\psi)\tau),\text{if matched with a firm}\label{eq:bdg_iw0_xl_1}\\
c_{u}+a'_{u} & \leq(1-\tilde{r}-\delta)a+b,\text{if unemployed}\label{eq:bdg_iw0_xl_2}
\end{align}

\end_inset


\begin_inset Formula $\left(P_{x\geq x_{u}^{*}}^{i_{w}=0}\right)$
\end_inset

:
 
\begin_inset Formula 
\begin{equation}
\mathbf{V}^{1}(h,z,x\geq x_{u}^{*},a,i_{w}=0)=\max_{a_{e}'}\left\{ u(c_{e})+\beta\mathbb{E}\mathbf{V}^{0}(h,z',x',a_{e}',i'_{w}=w)\right\} \label{eq:V_iw0_xh}
\end{equation}

\end_inset

s.t.
 
\begin_inset Formula 
\begin{equation}
c_{e}+a_{e}'\leq(1-\tilde{r}-\delta)a+\nu(k,x;\tilde{r},w,\tau)\label{eq:bdg_iw0_xh}
\end{equation}

\end_inset

where 
\begin_inset Formula 
\begin{equation}
\nu(k,x;\tilde{r},w,\tau)=\max_{n}\left\{ x^{1-\alpha-\gamma}k^{\alpha}n{}^{\gamma}-w(1+\psi\tau)n-rk-\frac{\kappa\rho n}{q(\theta)}\right\} .\label{eq:profit_emtrepreneur}
\end{equation}

\end_inset


\end_layout

\begin_layout Enumerate
Stop if 
\begin_inset Formula $\max\left\{ \left|\mathbf{V}^{1}-\mathbf{V}^{0}\right|,\left|f^{1}-f^{0}\right|\right\} \leq\epsilon$
\end_inset

.
 Set 
\begin_inset Formula $\mathbf{V}^{*}=\mathbf{V}^{1}$
\end_inset

,
 and 
\begin_inset Formula $f^{*}=f^{1}$
\end_inset

.
 Otherwise,
 set 
\begin_inset Formula $\mathbf{V}^{0}=\mathbf{V}^{1}$
\end_inset

,
 
\begin_inset Formula $f^{0}=f^{1}$
\end_inset

 and repeat from step (c).
 
\end_layout

\end_deeper
\begin_layout Enumerate
Generate a large number of individuals,
 
\begin_inset Formula $N=100000$
\end_inset

.
 For each agent 
\begin_inset Formula $j$
\end_inset

 assign a vector of initial condition 
\begin_inset Formula $\left(h_{t}^{j},z_{0}^{j},x_{0}^{j},a_{0}^{j},i_{w,0}^{j}\right)$
\end_inset

,
 where 
\begin_inset Formula $x_{0}^{j}\sim\Omega_{x}$
\end_inset

,
 
\begin_inset Formula $z_{0}^{j}\in\Omega_{z}$
\end_inset

,
 
\begin_inset Formula $i_{w,0}^{j}\in\Omega_{w}$
\end_inset

.
 
\end_layout

\begin_layout Enumerate
Simulate the economy for 
\begin_inset Formula $T$
\end_inset

 periods,
 where 
\begin_inset Formula $T$
\end_inset

 is sufficiently large.
 
\end_layout

\begin_layout Enumerate
Calculate the following statistics from the simulated path 
\begin_inset Formula $\left\{ h_{t}^{j},z_{t}^{j},x_{t}^{j},a_{t}^{j},i_{w,t}^{j},\mathcal{I}_{e,t}^{j},n_{t}^{j},k_{t}^{j}\right\} _{t=0}^{T}$
\end_inset

.
 
\begin_inset Formula 
\begin{align}
LS^{0} & =\frac{\sum_{j=1}^{N}\left(\iota_{i_{w}=1}\cdot z^{j}\right)}{N}\label{eq:agg_simulation_1}\\
KS^{0} & =\frac{\sum_{j=1}^{N}\left(\iota_{i_{w}=0}\cdot a^{j}+\iota_{i_{w}=1}\cdot a^{j}+\iota_{i_{w}=2}\cdot a^{j}-\iota_{i_{w}=0}\cdot k^{j}\right)}{\sum_{j=1}^{N}a^{j}}\label{eq:agg_simulation_2}\\
u_{t} & =\left(\int_{h}\iota_{i_{w}=0}+\int_{h}\iota_{i_{w}=2}\right)\cdot\int_{0}^{h_{u}^{*}}\\
v_{t} & =\int_{h}\iota_{i_{w}=1}\cdot\rho\\
p(\theta)_{t} & =\bar{m}\left(\frac{v_{t}}{u_{t}}\right)^{1-\mu}\\
G & =\int\tau wz
\end{align}

\end_inset

and 
\begin_inset Formula $\tau_{y}^{1}$
\end_inset

 that balances the government's budget.
 
\end_layout

\begin_layout Enumerate
Stop and set 
\begin_inset Formula $\left(r^{*},w^{*},\theta^{*}\right)=\left(r^{0},w^{0},\theta^{0}\right)$
\end_inset

,
 if 
\begin_inset Formula $\max\left\{ LS^{0},KS^{0},\left|\theta_{n}^{1}-\theta_{n}^{0}\right|\right\} \leq\epsilon$
\end_inset

.
 Otherwise,
 update aggregate variables (restart from step 2):
 
\begin_inset Formula 
\begin{align*}
r^{0} & =\chi r^{0}+(1-\chi)r^{1}\left(KS^{0}\right)\\
w^{0} & =\chi w^{0}+(1-\chi)w^{1}\left(LS^{0}\right)\\
p(\theta)^{0} & =\chi p(\theta)^{0}+(1-\chi)p(\theta)^{1}\\
\tau_{y}^{0} & =\chi\tau_{y}^{0}+(1-\chi)\tau_{y}^{1}
\end{align*}

\end_inset

where 
\begin_inset Formula $\chi\in(0,1)$
\end_inset

 is the step for updating aggregate variables.
 
\end_layout

\begin_layout Section*

\end_layout

\begin_layout Section*
Appendix Search and Matching
\end_layout

\begin_layout Standard
I am not sure how much of this is needed for coding purposes but this is the standard search and matching model.
 The stock of employed workers 
\begin_inset Formula $n_{t}$
\end_inset

 can be expressed as the current pool of workers who did not separate from firms,
 plus new hires
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
n_{t}=(1-\rho)n_{t-1}+m_{t-1}
\]

\end_inset

The matching function is Cobb-Douglass where
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
m_{t}=\bar{m}v_{t}^{1-\mu}u_{t}^{\mu}
\]

\end_inset


\begin_inset Formula $\bar{m}$
\end_inset

 is a match efficiency parameter ,
 
\begin_inset Formula $v$
\end_inset

 is vacancies,
 
\begin_inset Formula $u$
\end_inset

 is unemployment,
 and match elasticity is 
\begin_inset Formula $0<\mu<1$
\end_inset

.The hiring rate can be defined for firms as total number of new hires to the number of vacancies
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
q(\theta_{t})=\frac{m_{t}}{v_{t}}=\bar{m}\theta_{t}^{-\mu}
\]

\end_inset

where 
\begin_inset Formula $\theta_{t}=\frac{v_{t}}{u_{t}}$
\end_inset

is aggregate labour market tightness.
 Similarly we can define this from the perspective of the worker in the job-finding rate.
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
p(\theta_{t})=\frac{m_{t}}{u_{t}}=\bar{m}\theta_{t}^{1-\mu}
\]

\end_inset

The Job Creation Condition determines the amount of new vacancies an employer will post.
 In our model,
 most workers are on rolling contracts,
 so firms only need to post new vacancies after some workers separate from these rolling contracts.
 Usually in search and matching models the wage is determined ex-post of matching by Nash bargaining between the employer and employee.
 However,
 in our span-of-control model the wage has already been determined ex ante,
 as the wage is an endogenous variable that determines occupational choice.
 The marginal benefit that the new employee would bring to the firm is expressed as 
\begin_inset Formula $A$
\end_inset

 (which can be derived from the firms production function,
 
\begin_inset Formula $\gamma Xk^{\alpha}(zn)^{\gamma-1}$
\end_inset

).
 The 
\begin_inset Formula $JCC\text{ can be then expressed as the costs of replacing out workers on the \ensuremath{LHS} and the expected benefit on the \ensuremath{RHS.}}$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\kappa}{q(\theta_{t})}=A-w_{t}+\beta E_{t}\left[A-w_{t+1}+(1-\rho)\frac{\kappa}{q(\theta_{t+1})}\right]
\]

\end_inset

where 
\begin_inset Formula $\kappa$
\end_inset

 is the cost of posting a vacancy.
 
\begin_inset Note Comment
status open

\begin_layout Plain Layout
This is different from the standard JCC as usually production starts the period after matching so the JCC would be 
\begin_inset Formula $\frac{\kappa}{q(\theta_{t})}=+\beta E_{t}\left[A-w_{t+1}+(1-\rho)\frac{\kappa}{q(\theta_{t+1})}\right].$
\end_inset

 See alternative timing version to think about the problem this way,
 I am not sure it makes much difference.
 
\end_layout

\end_inset


\end_layout

\begin_layout Subsection*
Matching Steady States
\end_layout

\begin_layout Standard
To find the steady state of the employment equation 
\begin_inset Formula $n_{t}=(1-\rho)n_{t-1}+m_{t-1}$
\end_inset

,
 we use the fact that 
\begin_inset Formula $u=(1-n)$
\end_inset

 and 
\begin_inset Formula $m_{t}=\bar{m}v_{t}^{1-\mu}u_{t}^{\mu}.$
\end_inset

 Substituting and getting rid of time subscript gives 
\begin_inset Formula $(1-u)=(1-\rho)(1-u)+\bar{m}v^{1-\mu}u^{\mu}$
\end_inset

 which simplifies to 
\begin_inset Formula $\bar{m}v_{t}^{1-\mu}u_{t}^{\mu}=$
\end_inset


\begin_inset Formula $\rho(1-u)$
\end_inset

.
 Making 
\begin_inset Formula $v\text{\,the subject of the foruma gives us the Beveridge curve.}$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
v=\left(\frac{\rho(1-u)}{\bar{mu}}\right)^{1-\mu}u
\]

\end_inset

The steady state for the JCC can be found by using 
\begin_inset Formula $\frac{\kappa}{q(\theta_{t})}=A-w_{t}+\beta E_{t}\left[A-w_{t+1}+(1-\rho)\frac{\kappa}{q(\theta_{t+1})}\right]$
\end_inset

 and 
\begin_inset Formula $q(\theta_{t})=\bar{m}\theta_{t}^{-\mu}=\bar{m}\left(\frac{v_{t}}{u_{t}}\right)^{-\mu}$
\end_inset

.
 Substituting and getting rid of time subscripts yields 
\begin_inset Formula 
\[
\frac{\kappa}{\bar{m}}\left(\frac{v}{u}\right)^{\mu}=A-w_{t}+\beta\left[A-w+(1-\rho)\frac{\kappa}{\bar{m}}\left(\frac{v}{u}\right)^{\mu}\right]
\]

\end_inset


\end_layout

\begin_layout Standard
Simplifying yields the steady state of the JCC
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
1-\beta(1-\rho)\frac{\kappa}{\bar{m}}\left(\frac{v}{u}\right)^{\mu}=(1+\beta)\left[A-w\right]
\]

\end_inset


\end_layout

